# Whisper Transcription App — Environment Variables
# Copy this file to .env and adjust values as needed.

# Server
DEBUG=false
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated list)
ALLOW_ORIGINS=http://localhost:8000

# Upload limits
MAX_UPLOAD_MB=2000

# URL download limits
MAX_URL_DOWNLOAD_MB=500
URL_TIMEOUT_SECONDS=300

# Disable HuggingFace Hub network calls — models are loaded from local cache only
HF_HUB_OFFLINE=1

# Temp & model cache directories
TEMP_DIR=tmp
MODEL_CACHE_DIR=./models

# Concurrency & timeout
MAX_CONCURRENT_JOBS=1
MAX_TRANSCRIPTION_SECONDS=1800

# App version (informational)
VERSION=0.1.0
